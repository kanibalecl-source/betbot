# Skopiuj ten plik jako .env.local i wpisz swoje klucze.
# Ten plik jest tylko do lokalnego testu na laptopie.
# Nie wgrywaj .env.local na publiczne repozytorium.

API_FOOTBALL_KEY=TU_WKLEJ_API_FOOTBALL_KEY
ODDS_API_KEY=TU_WKLEJ_ODDS_API_KEY_JESLI_UZYWASZ
OPENAI_API_KEY=TU_WKLEJ_OPENAI_API_KEY_JESLI_CHCESZ_GPT

# Port lokalnego dashboardu
LOCAL_PORT=8501

# Opcjonalnie: co ile settlement sprawdza wyniki lokalnie
SETTLE_LOOP_MINUTES=180

