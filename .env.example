# Skopiuj jako .env i wpisz klucze, jeśli nie trzymasz ich w data_api.py albo secrets_config.py
API_FOOTBALL_KEY=
ODDS_API_KEY=

# Production security (minimum 32 random characters for API_KEY).
ENVIRONMENT=local
API_KEY=
BETTING_ENABLED=false
BETBOT_ADMIN_USERNAME=
# Generate with: python setup_secure_admin.py
BETBOT_ADMIN_PASSWORD_HASH=

# Persistent Railway Volume. Production startup is blocked without it.
PERSISTENT_DATA_DIR=/data
KANIBAL_REQUIRE_PERSISTENT_STORAGE=1
BETBOT_SERVER_BACKUP_REUSE_HOURS=0
BETBOT_SERVER_BACKUP_KEEP=5
BETBOT_SERVER_BACKUP_EMERGENCY_REUSE_HOURS=24
BETBOT_MAX_ODDS_AGE_SECONDS=300
API_FOOTBALL_ODDS_CACHE_SECONDS=240
API_FOOTBALL_ODDS_MIN_INTERVAL_SECONDS=2.5
API_FOOTBALL_RATE_LIMIT_COOLDOWN_SECONDS=65
BETBOT_STRATEGY_VERSION=strict-v1

# Quality diagnostics and evidence-based abstention. The gate stays fail-open
# until the derived policy has enough settled samples and passes integrity.
BETBOT_QUALITY_SELECTION_GATE_ENFORCE=true
BETBOT_QUALITY_DIAGNOSTIC_MIN_SEGMENT_SAMPLES=50
BETBOT_QUALITY_BASE_MIN_EDGE=0.02
BETBOT_MAX_DAILY_RECOMMENDATIONS=12
BETBOT_CLOSING_ODDS_WINDOW_MINUTES=45
BETBOT_GUARDIAN_MIN_LEDGER_COVERAGE=0.99
BETBOT_GUARDIAN_MIN_SETTLEMENT_COVERAGE=0.95
BETBOT_GUARDIAN_MAX_API_ERRORS_24H=5
BETBOT_FEATURE_IMPACT_MIN_SAMPLES=100
BETBOT_QUALITY_MIN_CLOSING_COVERAGE=0.80
BETBOT_QUALITY_MIN_CLV_SAMPLES=100
BETBOT_QUALITY_QUARANTINE_WINDOW=100
BETBOT_MODEL_VERSION=champion-current
BETBOT_QUALITY_SEGMENT_MIN_SAMPLES=500
BETBOT_QUALITY_MAX_SEGMENTS=12
BETBOT_QUALITY_WF_MIN_TEST_SAMPLES=300
BETBOT_QUALITY_WF_MIN_FOLDS=4
BETBOT_LIVE_SHADOW_MIN_SAMPLES=300

# Co ile minut bot ma pobierać typy
BOT_LOOP_MINUTES=120

# Co ile minut system ma sprawdzać wyniki
SETTLE_LOOP_MINUTES=180

# Port panelu WWW
WEB_PORT=8000
# OpenAI GPT-web match analyzer
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MATCH_MODEL=gpt-4.1-mini
GPT_MAX_MATCHES=20
GPT_MATCH_SLEEP_SECONDS=0.3
