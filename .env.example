# Skopiuj jako .env i wpisz klucze, jeśli nie trzymasz ich w data_api.py albo secrets_config.py
API_FOOTBALL_KEY=
ODDS_API_KEY=

# Production security (minimum 32 random characters for API_KEY).
ENVIRONMENT=local
API_KEY=
BETTING_ENABLED=false
BETBOT_ADMIN_USERNAME=
# Generate with: python setup_secure_admin.py
BETBOT_ADMIN_PASSWORD_HASH=

# Persistent Railway Volume. Production startup is blocked without it.
PERSISTENT_DATA_DIR=/data
KANIBAL_REQUIRE_PERSISTENT_STORAGE=1
BETBOT_SERVER_BACKUP_REUSE_HOURS=0
BETBOT_SERVER_BACKUP_KEEP=5
BETBOT_SERVER_BACKUP_EMERGENCY_REUSE_HOURS=24
BETBOT_MAX_ODDS_AGE_SECONDS=300
BETBOT_STRATEGY_VERSION=strict-v1

# Co ile minut bot ma pobierać typy
BOT_LOOP_MINUTES=120

# Co ile minut system ma sprawdzać wyniki
SETTLE_LOOP_MINUTES=180

# Port panelu WWW
WEB_PORT=8000
# OpenAI GPT-web match analyzer
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MATCH_MODEL=gpt-4.1-mini
GPT_MAX_MATCHES=20
GPT_MATCH_SLEEP_SECONDS=0.3
